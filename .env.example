# ============================================================================
# RubberIQ — environment variables
# Copy to `.env` (gitignored). Never commit secrets.
# ============================================================================

NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:5173

# Postgres — guru-boxz-db cluster, database `rubberiq`
DATABASE_URL=postgres://USER:PASS@HOST:25060/rubberiq?sslmode=require

# JWT — 32+ chars
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Anthropic (intake vision + multilingual generation)
ANTHROPIC_API_KEY=

# Stripe — both Connect (online) and Terminal (in-person)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Sentry (org: guru-boxz)
SENTRY_DSN=
SENTRY_RELEASE=

# Wholesaler adapters — set ONE
WHOLESALE_ADAPTER=tirewire
TIREWIRE_API_KEY=
TIRECONNECT_API_KEY=
