{
  "name": "@rubberiq/api-server",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "health:aggregate": "tsx src/scripts/aggregate-health.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "@rubberiq/anthropic": "workspace:*",
    "@rubberiq/db": "workspace:*",
    "@sentry/node": "^8.55.0",
    "@sentry/profiling-node": "^8.55.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "catalog:",
    "express": "catalog:",
    "helmet": "^8.0.0",
    "i18next": "catalog:",
    "i18next-fs-backend": "^2.6.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "stripe": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "~5.9.2",
    "vitest": "^2.1.8"
  }
}
